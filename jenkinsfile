pipeline {
    agent any

       tools {
        nodejs 'nodejs16'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        MY_KEY = credentials('my-secret-key')
        DB_USER = credentials('db-user')
        DB_PASSWORD = credentials('db-password')
        DB_NAME = 'my-database'
        CONNECTION_NAME = 'my-connection-name'
    }

    stages {
     stage('Install Tools')
         steps{
           sh "python3 -v"
           sh "docker -v"
              }
           }
    stage("Sonarqube Analysis") {
        steps {
            withSonarQubeEnv('sonarqube-server') {
            sh "$SCANNER_HOME/bin/sonar-scanner -Dsonar.projectName=Online-Notes-App \
            -Dsonar.scm.provider=git \
            -Dsonar.sources=. \
            -Dsonar.projectKey=Online-Notes-App \
            -Dsonar.login=$AUTH_TOKEN"
                    }
                }
            }   

  }
}
